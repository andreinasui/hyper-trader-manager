{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ark-ui": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ark-ui/mcp"
      ],
      "enabled": true
    },
    "tanstack": {
      "type": "local",
      "command": [
        "npx",
        "@tanstack/cli",
        "mcp"
      ],
    },
    "privy-docs": {
      "type": "remote",
      "url": "https://docs.privy.io/mcp"
    }
  },
  "tools": {
    "ark-ui*": false,
    "tanstack*": false,
    "privy-docs*": false,
  }
}
