# HyperTrader Self-Hosted Configuration
#
# Copy this file to .env.dev for local development
# or .env.prod for production deployment
#
# Generate secrets with:
#   openssl rand -hex 32

# ==================== Environment ====================
ENVIRONMENT=development  # development | production

# ==================== Database ====================
# SQLite database file path (will be created if it doesn't exist)
DATABASE_URL=sqlite:///./data/hypertrader.db

# ==================== Security & Authentication ====================
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# ==================== Self-Hosted Configuration ====================
# Public URL where the application is accessible
PUBLIC_BASE_URL=http://localhost:80
PUBLIC_PORT=80

# Docker socket for managing trader containers
DOCKER_SOCKET=unix:///var/run/docker.sock

# Runtime mode (currently only docker is supported)
RUNTIME_MODE=docker

# ==================== Server ====================
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# ==================== Logging ====================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==================== HTTP Client ====================
HTTP_TIMEOUT=10.0
