# HyperTrader API Configuration

# Database
DATABASE_URL=postgresql://hypertrader:password@postgres:5432/hypertrader

# Application
DEBUG=False
SECRET_KEY=change-me-in-production

# JWT Authentication (Phase 4)
JWT_SECRET_KEY=change-me-in-production-jwt-secret-use-strong-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Kubernetes
K8S_NAMESPACE=hyper-trader
GITHUB_REPO=andreinasui/hyper-trader

# Database Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
