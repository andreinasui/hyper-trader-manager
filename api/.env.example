# HyperTrader API Configuration
#
# Copy this file to:
#   .env.dev      - for local development
#   .env.staging  - for staging environment
#   .env.prod     - for production deployment
#
# The app automatically loads the correct file based on ENVIRONMENT:
#   ENVIRONMENT=development  → .env.dev
#   ENVIRONMENT=staging      → .env.staging
#   ENVIRONMENT=production   → .env.prod
#
# Or explicitly override with: ENV_FILE=/path/to/custom.env

# ==================== Environment ====================
ENVIRONMENT=development  # development | staging | production

# ==================== Database ====================
DATABASE_URL=postgresql://hypertrader:password@localhost:5432/hypertrader
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==================== Privy Authentication ====================
# Required in staging/production environments
PRIVY_APP_ID=your_app_id_here
PRIVY_APP_SECRET=your_secret_here

# Optional: Custom JWKS endpoint (defaults to Privy's standard endpoint)
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/{app_id}/jwks.json
# PRIVY_JWKS_CACHE_TTL=3600

# ==================== Server ====================
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# ==================== Logging ====================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==================== HTTP Client ====================
HTTP_TIMEOUT=10.0

# ==================== Kubernetes ====================
K8S_ENABLED=true
K8S_NAMESPACE=hyper-trader
GITHUB_REPO=andreinasui/hyper-trader
IMAGE_TAG=latest  # Docker image tag for all trader pods
TEMPLATES_DIR=api/templates
RECONCILIATION_INTERVAL=30
