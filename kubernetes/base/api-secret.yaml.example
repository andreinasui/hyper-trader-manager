# HyperTrader API Secret - Example Configuration
# Copy this file to api-secret.yaml and fill in actual values
#
# IMPORTANT: This file contains sensitive data. Do NOT commit actual secrets!
#
# Generate an encryption key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
apiVersion: v1
kind: Secret
metadata:
  name: api-secret
  namespace: hyper-trader
  labels:
    app: hypertrader-api
    managed-by: infra-ctl
type: Opaque
stringData:
  # PostgreSQL connection string
  # Format: postgresql://user:password@host:port/database
  database-url: postgresql://hypertrader:CHANGE_ME@postgres:5432/hypertrader
  
  # Fernet encryption key for private key encryption
  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  encryption-key: GENERATE_NEW_KEY_DO_NOT_USE_THIS_VALUE
