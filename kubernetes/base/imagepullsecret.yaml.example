# Create this secret to pull images from private GHCR
# 
# Generate GitHub Personal Access Token (PAT) with 'read:packages' scope
# Then create the secret:
#
# kubectl create secret docker-registry ghcr-secret \
#   --docker-server=ghcr.io \
#   --docker-username=<your-github-username> \
#   --docker-password=<your-github-pat> \
#   --namespace=hyper-trader
#
# Or apply this YAML after base64 encoding the .dockerconfigjson:
#
# apiVersion: v1
# kind: Secret
# metadata:
#   name: ghcr-secret
#   namespace: hyper-trader
# type: kubernetes.io/dockerconfigjson
# data:
#   .dockerconfigjson: <base64-encoded-docker-config>
