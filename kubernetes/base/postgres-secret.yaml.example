# PostgreSQL Secret Example
# Copy this file to postgres-secret.yaml and update the password
# NEVER commit the actual secret file to version control!
#
# Usage:
#   cp postgres-secret.yaml.example postgres-secret.yaml
#   # Edit postgres-secret.yaml with a secure password
#   kubectl apply -f postgres-secret.yaml

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: hyper-trader
  labels:
    app: postgres
    managed-by: infra-ctl
type: Opaque
stringData:
  username: hypertrader
  password: CHANGE_ME_TO_SECURE_PASSWORD
