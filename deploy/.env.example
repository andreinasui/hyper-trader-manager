# HyperTrader Manager Configuration
# Copy this file to .env and fill in your values

# ============================================
# Network
# ============================================
# Port to expose publicly (default: 80)
PUBLIC_PORT=80

# ============================================
# API Configuration
# ============================================
# Environment
ENVIRONMENT=production

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Data Persistence
# ============================================
# Path inside the container where SQLite database and app data are stored
# Mounted from ./data on the host
DATA_DIR=/app/data

# ============================================
# Docker Integration
# ============================================
# Docker socket path (for managing trader services via Docker Swarm)
# Usually /var/run/docker.sock on Linux
DOCKER_SOCKET=/var/run/docker.sock

# GID of the docker group on the host (run: getent group docker | cut -d: -f3)
# Allows the API container to access the Docker socket
DOCKER_GID=999

# Docker overlay network name for trader Swarm services
# Note: Docker Swarm mode is initialized automatically on first trader creation
TRADER_NETWORK=hypertrader_default

# ============================================
# CORS
# ============================================
# Allowed origins for CORS (comma-separated)
# Set to your domain in production
CORS_ORIGINS=http://localhost

# ============================================
# Optional: Admin user (created on first start)
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
