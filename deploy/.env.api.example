# ============================================
# HyperTrader API - Production Configuration
# ============================================
# Environment variables for the FastAPI backend service
# Copy to api.env and configure for your environment

# ============================================
# Environment
# ============================================
ENVIRONMENT=production

# ============================================
# Database
# ============================================
# SQLite database path (absolute path inside container)
DATABASE_URL=sqlite:////app/data/hypertrader.db

# ============================================
# Self-Hosted Configuration
# ============================================
# Public base URL for the application (used in SSL setup, redirects, etc.)
PUBLIC_BASE_URL=http://localhost

# Docker socket path (must match DOCKER_SOCK in .env)
DOCKER_SOCKET=unix:///var/run/docker.sock

# Docker image tag for trader containers
IMAGE_TAG=latest

# Base directory for app data (Traefik config, SSL certs, trader configs)
# This is the path inside the container
DATA_DIR=/app/data

# ============================================
# Server Configuration
# ============================================
# Server host (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Server port (internal container port)
PORT=8000

# Number of Uvicorn workers
WORKERS=1

# Debug mode (false for production)
DEBUG=false

# ============================================
# Logging
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# For production with domain: https://yourdomain.com,https://www.yourdomain.com
# For IP access: http://YOUR_VPS_IP
CORS_ORIGINS=http://localhost

# ============================================
# Rate Limiting
# ============================================
# Enable rate limiting (recommended for production)
RATE_LIMIT_ENABLED=false

# Number of requests allowed per window
RATE_LIMIT_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW=60

# ============================================
# HTTP Client
# ============================================
# HTTP client timeout in seconds
HTTP_TIMEOUT=10.0

# ============================================
# API Metadata
# ============================================
# API title (shown in OpenAPI docs)
API_TITLE=HyperTrader API

# API version
API_VERSION=1.0.0
