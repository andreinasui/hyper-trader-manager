    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "buffer": "^6.0.3",
    "jsdom": "^27.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
