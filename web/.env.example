# HyperTrader Web UI Configuration

# API URL (backend endpoint)
VITE_API_URL=http://localhost:8000

# Privy Configuration
# Get your App ID from: https://dashboard.privy.io
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Backend Wallet Signing
# Key Quorum ID for the backend's authorization key (created in Privy Dashboard)
# This allows your backend to sign transactions on behalf of users
VITE_PRIVY_SIGNER_KEY_QUORUM_ID=your_signer_key_quorum_id_here

# Optional: Policy ID to restrict what backend can do (leave empty for unrestricted access)
VITE_PRIVY_ALL_ACTIONS_POLICY_ID=

# Application
NODE_ENV=production
PORT=3000
